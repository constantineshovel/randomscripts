# -*- coding: utf-8 -*-

import arcpy
import arcpy.sa as sa
import tkinter as tk
import tkinter.filedialog as d

print("Welcome to FOGU - Burn Severity & Wildfire Perimeter tool.")

# Setup base del workspace
root = tk.Tk()
root.withdraw()
print("Select the folder where to save the files")
arcpy.env.workspace = d.askdirectory(title="Select Folder to Save Files")
arcpy.env.workspace = arcpy.env.workspace.replace('/', '\\')
arcpy.env.overwriteOutput = True
print("Workspace set to:", arcpy.env.workspace)


def FOGU():
    """
    Welcome to the FOGU module. Let's calculate NBR, dNBR, and draft maps for Burn Severity,
    reclassified Burn Severity (PFES), and Wildfire perimeter. 
    Works with any sensor providing NIR and SWIR bands!
    """
    arcpy.env.overwriteOutput = True

    # Percorsi di output specifici per FOGU
    outdir = arcpy.env.workspace + "\\"
    onirpre = outdir + "nirpre.tif"
    oswirpre = outdir + "swirpre.tif"
    onirpost = outdir + "nirpost.tif"
    oswirpost = outdir + "swirpost.tif"
    onbrpre = outdir +"nbrprefire.tif"
    onbrpost = outdir + "nbrpostfire.tif"
    odnbr = outdir + "dNBR.tif"
    obs = outdir + "BURNSEVERITY.tif"
    oreclassBS = outdir + "BURNSEVERITYCLASSESPFES.tif"
    owfp = outdir + "WILDFIREPERIMETER.tif"

    # IMPORT IMAGES
    print("Select the Prefire NIR image")
    h = d.askopenfilename(title="Select the Prefire NIR image")
    print("Select the Prefire SWIR image")
    i = d.askopenfilename(title="Select the Prefire SWIR image")
    print("Select the Postfire NIR image")
    j = d.askopenfilename(title="Select the Postfire NIR image")
    print("Select the Postfire SWIR image")
    k = d.askopenfilename(title="Select the Postfire SWIR image")
    
    arcpy.MakeRasterLayer_management(h, "NIR PREFIRE ORIG")
    arcpy.CopyRaster_management("NIR PREFIRE ORIG", onirpre, "", "", "", "", "", "64_BIT", "", "", "TIFF", "")
    arcpy.MakeRasterLayer_management(onirpre, "NIR PREFIRE TIF")
    
    arcpy.MakeRasterLayer_management(i, "SWIR PREFIRE ORIG")
    arcpy.CopyRaster_management("SWIR PREFIRE ORIG", oswirpre, "", "", "", "", "", "64_BIT", "", "", "TIFF", "")
    arcpy.MakeRasterLayer_management(oswirpre, "SWIR PREFIRE TIF")
    
    arcpy.MakeRasterLayer_management(j, "NIR POSTFIRE ORIG")
    arcpy.CopyRaster_management("NIR POSTFIRE ORIG", onirpost, "", "", "", "", "", "64_BIT", "", "", "TIFF", "")
    arcpy.MakeRasterLayer_management(onirpost, "NIR POSTFIRE TIF")
    
    arcpy.MakeRasterLayer_management(k, "SWIR POSTFIRE ORIG")
    arcpy.CopyRaster_management("SWIR POSTFIRE ORIG", oswirpost, "", "", "", "", "", "64_BIT", "", "", "TIFF", "")
    arcpy.MakeRasterLayer_management(oswirpost, "SWIR POSTFIRE TIF")

    # PREFIRE
    NBRpre = sa.Divide(sa.Minus("NIR PREFIRE TIF", "SWIR PREFIRE TIF"), sa.Plus("NIR PREFIRE TIF", "SWIR PREFIRE TIF"))
    NBRpre.save(onbrpre)
    arcpy.MakeRasterLayer_management(onbrpre, "NBR PREFIRE")
    print("FOGU: FINISHED - 1 PREFIRE NBR")

    # POSTFIRE
    NBRpost = sa.Divide(sa.Minus("NIR POSTFIRE TIF", "SWIR POSTFIRE TIF"), sa.Plus("NIR POSTFIRE TIF", "SWIR POSTFIRE TIF"))
    NBRpost.save(onbrpost)
    arcpy.MakeRasterLayer_management(onbrpost, "NBR POSTFIRE")
    print("FOGU: FINISHED - 2 POSTFIRE NBR")

    # dNBR
    dNBR = sa.Minus("NBR PREFIRE", "NBR POSTFIRE")
    dNBR.save(odnbr)
    arcpy.MakeRasterLayer_management(odnbr, "dNBR")
    print("FOGU: FINISHED - 3 dNBR")
    
    # Burn Severity
    min_dNBR = arcpy.GetRasterProperties_management("dNBR", "MINIMUM", "Band_1")
    max_dNBR = arcpy.GetRasterProperties_management("dNBR", "MAXIMUM", "Band_1")
    
    BS = sa.Reclassify("dNBR", "Value", sa.RemapRange([[min_dNBR, -0.25, 1], [-0.25, -0.1, 2], 
                                                      [-0.1, 0.1, 3], [0.1, 0.27, 4], 
                                                      [0.27, 0.44, 5], [0.44, 0.66, 6], 
                                                      [0.66, max_dNBR, 7]]), "NODATA") 
    BS.save(obs)
    arcpy.MakeRasterLayer_management(obs, "Burn Severity Classes")
    print("FOGU: FINISHED - 4 Burn Severity map drafting")

    # reclassified Burn Severity for PFES map drafting
    reclassBS = sa.Reclassify("Burn Severity Classes", "Value", sa.RemapRange([[1, 3, 1], [4, 4, 2], 
                                                                               [5, 5, 3], [6, 6, 4], 
                                                                               [7, 7, 5]]), "NODATA") 
    reclassBS.save(oreclassBS)
    arcpy.MakeRasterLayer_management(oreclassBS, "Reclassified Burn Severity")
    print("FOGU: FINISHED - 5 Burn Severity for PFES")

    # Wildfire perimeter
    WFP = sa.Reclassify("Burn Severity Classes", "Value", sa.RemapRange([[1, 3, 0], [4, 7, 1]]), "NODATA") 
    WFP.save(owfp)
    arcpy.MakeRasterLayer_management(owfp, "Wildfire Perimeter")
    print("FOGU: FINISHED - 6 Wildfire Perimeter drafting")

# Launch with FOGU()
