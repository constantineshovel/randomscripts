        print('Usage: IC("METER", "DINF")')
        print('DEM UNITS: "INCH", "FOOT", "YARD", "MILE_US", "METER", "KILOMETER", etc.')
        print('Algorithms: "D8", "DINF"')
    elif module == "RIU":
        print("Welcome to RIU. Drafts watersheds and river networks. Call the function using RIU().")
    elif module == "commands":
        print("Available commands: IC(dem_unit, alg, Wsett), RIU(), help(module), ammenta()")
    elif module == "ABOUT":
        print("References: Borselli et al. (2008), Cavalli et al. (2013), Riley et al. (1999).")

